# OS / editor / local tooling
.DS_Store
.idea/
.vscode/
.claude/

# Python caches / env
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.venv/
venv/

# Build / logs / temp
*.log
*.tmp
*.bak

# Jupyter checkpoints
.ipynb_checkpoints/

# Local databases and binary artifacts
*.db
*.duckdb
*.sqlite
*.sqlite3
*.parquet

# Large generated data (keep repo lightweight)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

outputs/reports/*
!outputs/reports/informe_analitico_cbm_ferroviario.pdf

# Canonical dashboard is intentionally kept in version control
!outputs/dashboard/
!outputs/dashboard/centro-control-mantenimiento-ferroviario.html
